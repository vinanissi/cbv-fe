{
  "name": "cf-app-template",
  "version": "1.0.0",
  "description": "Cloudflare Workers or Pages application deployed via Wrangler CLI",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npm run build:worker",
    "build:worker": "echo 'Build script - customize for your project'",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env prod",
    "test": "echo 'Tests - customize for your project'"
  },
  "keywords": [
    "cf_app",
    "cloudflare",
    "workers",
    "wrangler",
    "idp"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}

